<%- layout("/layouts/boilerplate") %>

  <div class="row mt-1">
    <div class="col-10 offset-1 col-md-8 offset-md-3 mb-3 mt-5">
      <h3>
        <%= listing.title %>
      </h3>
    </div>
    <div
      class="card col-10 offset-1 col-md-6 offset-md-3 border-0 show-card d-flex justify-content-center align-items-flex-start mb-5">

      <img src="<%= listing.image.url || listing.image %>" class="card-img-top show-img" alt="<%= listing.title %>"
        style="height: 400px; object-fit: cover;">
      <div class="card-body">
        <p class="card-text">Owned by <i>
            <%= listing.owner ? listing.owner.username : "unknown" %>
          </i>
        </p>
        <p class="card-text">
          <%= listing.description %>
        </p>
        <p class="card-text">
          &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
        </p>
        <p class="card-text">
          <%= listing.location %>, <%= listing.country %>
        </p>
      </div>
    </div>

    <br />

    <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){%>
      <div class="col-10 offset-1 col-md-8 offset-md-3 mb-3 d-flex gap-3 flex-wrap">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
          <button class="btn btn-danger del">Delete</button>
        </form>
        <a href="/listings" class="btn btn-secondary">Back to All Listings</a>
      </div>
      <%}%>
        <hr />

        <div class="col-10 offset-1 col-md-8 offset-md-3 mb-3">
          <h3>Where you'll be</h3>
          <div id="map" style="height: 350px; width: 80%; border-radius: 15px;"></div>
        </div>


        <div class="col-10 offset-1 col-md-8 offset-md-3 mb-3 mt-5">
          <hr>
          <% if(currUser){ %>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
              <div class="mb-3 mt-3">
                <label class="form-label">Rating</label>
                <fieldset class="starability-slot">
                  <legend>First rating:</legend>
                  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked
                    aria-label="No rating." />
                  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                  <label for="first-rate1" title="Terrible">1 star</label>
                  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                  <label for="first-rate2" title="Not good">2 stars</label>
                  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                  <label for="first-rate3" title="Average">3 stars</label>
                  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                  <label for="first-rate4" title="Very good">4 stars</label>
                  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                  <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
              </div>
              <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                  required></textarea>
                <div class="invalid-feedback">Please add comment for review.</div>
              </div>
              <button class="btn btn-outline-dark mb-5">Submit</button>
            </form>
            <%}%>
              <% if(listing.reviews.length> 0) { %>
                <p><b>All Reviews</b></p>
                <div class="row mt-3">
                  <% for(review of listing.reviews) { %>
                    <div class="card col-12 col-md-5 ms-md-3 mb-3 shadow-sm">
                      <div class="card-body">
                        <h5 class="card-title">
                          @<%= review.author ? review.author.username : "anonymous" %>
                        </h5>
                        <p class="card-text">
                          <%= review.comment %>
                        </p>
                        <p class="card-text">
                          <span class="starability-result" data-rating="<%= review.rating %>"></span>
                        </p>

                        <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>
                          <form class="mb-3" method="POST"
                            action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                            <button class="btn btn-sm btn-dark">Delete</button>
                          </form>
                          <% } %>
                      </div>
                    </div>
                    <% } %>
                </div>
                <%} %>
        </div>
  </div>

  <script>
    const address = "<%= listing.location %>, <%= listing.country %>";

    // Coordinates fetch 
    fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${address}`)
      .then(response => response.json())
      .then(data => {
        if (data.length > 0) {
          const lat = data[0].lat;
          const lon = data[0].lon;
          // Map initialize 
          const map = L.map('map').setView([lat, lon], 13);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
          // Marker add
          L.marker([lat, lon]).addTo(map)
            .bindPopup("Listing location here!")
            .openPopup();
        }
      })
      .catch(err => console.error("Map error:", err));
  </script>



 